---
import BaseLayout from "../../layouts/BaseLayout.astro";

const modules = import.meta.glob("../../content/pitfalls/*.md", { eager: true });
const pitfalls = Object.entries(modules)
  .map(([path, module]) => {
    const entry = module as { frontmatter: { title: string; summary: string } };
    const slug = path.split("/").pop()?.replace(".md", "") ?? "";
    return { slug, ...entry.frontmatter };
  })
  .sort((a, b) => a.title.localeCompare(b.title, "zh-CN"));
---

<BaseLayout title="踩坑与修正">
  <h1>踩坑与修正</h1>
  <p>这里记录真实误解、判断证据和修正方式。</p>

  <div class="list">
    {pitfalls.map((pitfall) => (
      <a class="card" href={`/pitfalls/${pitfall.slug}/`}>
        <strong>{pitfall.title}</strong>
        <span>{pitfall.summary}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .list {
    display: grid;
    gap: 14px;
    margin-top: 28px;
  }

  .card {
    display: grid;
    gap: 8px;
    padding: 18px;
    border: 1px solid #d8d1c4;
    border-radius: 8px;
    background: #fff;
    text-decoration: none;
  }

  .card span {
    color: #555;
  }
</style>
