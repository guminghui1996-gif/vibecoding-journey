---
const { title = "代码小白的 AI 产品构建记录" } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <main class="page">
      <nav class="nav">
        <a href="/">首页</a>
        <a href="/days/">学习时间线</a>
        <a href="/topics/">主题索引</a>
        <a href="/pitfalls/">踩坑记录</a>
      </nav>
      <slot />
    </main>
  </body>
</html>

<style>
  :global(body) {
    margin: 0;
    background: #f7f5ef;
    color: #151515;
    font-family: Arial, "Microsoft YaHei", sans-serif;
  }

  :global(a) {
    color: inherit;
  }

  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: 32px 24px 72px;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 56px;
  }

  .nav a {
    color: #444;
    text-decoration: none;
  }

  :global(h1) {
    font-size: 44px;
    line-height: 1.15;
    margin: 0 0 18px;
  }

  :global(h2) {
    margin-top: 42px;
  }

  :global(p),
  :global(li) {
    line-height: 1.8;
  }

  :global(code),
  :global(pre) {
    font-family: Consolas, "Courier New", monospace;
  }

  :global(pre) {
    overflow-x: auto;
    padding: 16px;
    background: #191919;
    color: #f5f5f5;
  }

  :global(blockquote) {
    margin-left: 0;
    padding-left: 18px;
    border-left: 4px solid #222;
    color: #444;
  }
</style>
